{
  "name": "figma-prototype-mcp",
  "version": "0.30.2",
  "description": "MCP server for creating Figma prototype interactions via natural language",
  "license": "MIT",
  "author": "smooeach",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smooeach/figma-prototype-mcp.git"
  },
  "homepage": "https://github.com/smooeach/figma-prototype-mcp#readme",
  "bugs": {
    "url": "https://github.com/smooeach/figma-prototype-mcp/issues"
  },
  "keywords": [
    "figma",
    "figma-plugin",
    "prototype",
    "mcp",
    "model-context-protocol",
    "claude"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "dist/server/index.js",
  "bin": {
    "figma-prototype-mcp": "dist/server/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "tsx src/server/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^5.2.1",
    "ws": "^8.18.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.108.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
